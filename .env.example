# Not currently read by any code — the app runs entirely on mock data
# (src/lib/mock-data.ts, src/lib/mock-vocabulary.ts). Set these now so
# they're in place for when frontend pages switch to real fetch() calls
# against the backend in server/. See docs/DEPLOYMENT.md.

NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
