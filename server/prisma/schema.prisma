// FrenchMaster backend data model.
//
// Scope note: this schema models enough of the real domain to back the
// Dashboard endpoint (GET /api/dashboard) with genuine aggregation, plus
// the auth flow needed to protect it. Tables for the rest of the product
// (full lesson content authoring, exams content, payments, CMS, etc.) are
// intentionally minimal or absent — see server/README.md "Out of scope".

generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL: pooled connection (Supabase Supavisor, port 6543,
// ?pgbouncer=true) — used for normal app queries.
// DIRECT_URL: direct connection (port 5432) — used only by `prisma migrate`,
// which needs a non-pooled connection to run reliably.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CEFRLevel {
  A1
  A2
  B1
  B2
}

enum SkillKey {
  pronunciation
  grammar
  listening
  reading
  speaking
  vocabulary
}

enum Role {
  ADMIN
  MODERATOR
  PREMIUM
  USER
}

// ACTIVE is the only status that may authenticate — requireAuth rejects
// SUSPENDED/BANNED on every request (not just at login), so an admin action
// takes effect immediately rather than waiting for the access token to
// expire. See src/middleware/auth.ts.
enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum AchievementIcon {
  flame
  mic
  trophy
  book
  target
  medal
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

enum WordGender {
  masculine
  feminine
  neutral
}

enum PartOfSpeech {
  noun
  verb
  adjective
  adverb
  phrase
  expression
}

enum MasteryStatus {
  new
  learning
  mastered
}

enum ExerciseType {
  multiple_choice
  true_false
  fill_blank
  arrange_sentence
  match
  audio_question
  image_question
  typing
  speaking_prompt
}

// Mirrors TEF Canada's real 4 test sections (see docs/EXAM_STRUCTURE.md):
// Compréhension écrite, Expression écrite, Compréhension orale, Expression
// orale — each with its own real duration and point scale.
enum ExamSectionType {
  READING_COMPREHENSION
  WRITING_EXPRESSION
  LISTENING_COMPREHENSION
  SPEAKING_EXPRESSION
}

enum ExamQuestionType {
  multiple_choice // auto-graded: reading/listening comprehension
  writing_task // human-graded: expression écrite section A/B
  speaking_task // human-graded: expression orale subjects
}

enum ExamAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum PronunciationSource {
  vocabulary_word
  exercise
  exam_speaking
}

// ---------------------------------------------------------------------------
// Auth / Users
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String? // nullable: OAuth-only users have no password
  name         String
  avatarUrl    String?
  role         Role      @default(USER)
  status       AccountStatus @default(ACTIVE)

  authProvider   AuthProvider @default(EMAIL)
  googleId       String?      @unique
  appleId        String?      @unique

  currentLevel   CEFRLevel @default(A1)
  levelProgress  Int       @default(0) // 0-100 through currentLevel
  coins          Int       @default(0)

  goalMinutesPerDay Int @default(15)

  // Drives which translation column shows alongside French/English
  // everywhere vocabulary is rendered — see Language/VocabularyTranslation
  // below. Always defaults to "en" so no user is ever left without a value.
  primaryLanguageCode String   @default("en")
  primaryLanguage     Language @relation(fields: [primaryLanguageCode], references: [code])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  refreshTokens      RefreshToken[]
  lessonProgress     LessonProgress[]
  skillScores        SkillScoreSnapshot[]
  mistakeLogs        MistakeLog[]
  userAchievements   UserAchievement[]
  dailyActivity      DailyActivity[]
  xpTransactions     XpTransaction[]
  vocabularyProgress UserVocabularyProgress[]
  exerciseAttempts   ExerciseAttempt[]
  examAttempts       ExamAttempt[]
  pronunciationAttempts PronunciationAttempt[]

  @@index([currentLevel])
  @@index([role])
  @@index([status])
  @@index([primaryLanguageCode])
  @@map("users")
}

// Refresh tokens are stored hashed (never the raw token) so a DB leak does
// not expose usable tokens. Rotation: each refresh issues a new token row
// and revokes (sets revokedAt on) the one presented.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  replacedByTokenId String?
  createdByIp String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Curriculum (minimal — just enough to resolve continueLesson/todaysLesson)
// ---------------------------------------------------------------------------

model Unit {
  id          String    @id @default(uuid())
  title       String
  description String?
  level       CEFRLevel
  order       Int // display/sequence order within the level

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lessons Lesson[]

  @@index([level, order])
  @@map("units")
}

model Lesson {
  id                String    @id @default(uuid())
  unitId            String
  unit              Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  title             String
  subtitle          String
  level             CEFRLevel
  order             Int // sequence order within the unit
  estimatedMinutes  Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  progressRecords LessonProgress[]
  vocabularyLinks LessonVocabulary[]
  grammarPoints   GrammarPoint[]
  dialogues       ConversationDialogue[]
  readingPassages ReadingPassage[]
  listeningClips  ListeningClip[]
  exercises       Exercise[]

  @@index([unitId, order])
  @@index([level])
  @@map("lessons")
}

// ---------------------------------------------------------------------------
// Lesson content
// ---------------------------------------------------------------------------
//
// Scope note: this is the first fully-modeled lesson end-to-end (see
// prisma/seed.ts "Bonjour — Greetings" for the gold-standard A1 example that
// proves this pattern before scaling it across the rest of the A1-B2
// curriculum). Every content type here maps to a section CLAUDE.md's
// "Lesson Structure" calls for: Vocabulary (existing VocabularyWord catalog,
// linked here), Grammar, Conversation, Reading, Listening, Practice/Quiz.

// Links a lesson to catalog VocabularyWord rows it teaches. A word can
// appear in multiple lessons (e.g. reviewed later); a lesson's word list is
// this table in `order`, not VocabularyWord.unitTitle (still a free-text
// display label, unrelated to this relation — see the note on
// VocabularyWord below).
model LessonVocabulary {
  id       String         @id @default(uuid())
  lessonId String
  lesson   Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  wordId   String
  word     VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  order    Int

  @@unique([lessonId, wordId])
  @@index([lessonId, order])
  @@map("lesson_vocabulary")
}

model GrammarPoint {
  id          String @id @default(uuid())
  lessonId    String
  lesson      Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  explanation String // markdown
  order       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examples GrammarExample[]

  @@index([lessonId, order])
  @@map("grammar_points")
}

model GrammarExample {
  id             String       @id @default(uuid())
  grammarPointId String
  grammarPoint   GrammarPoint @relation(fields: [grammarPointId], references: [id], onDelete: Cascade)
  frenchText     String
  englishText    String
  order          Int

  @@index([grammarPointId, order])
  @@map("grammar_examples")
}

model ConversationDialogue {
  id       String @id @default(uuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String
  context  String // e.g. "Restaurant", "Airport", "Meeting a colleague"
  order    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines DialogueLine[]

  @@index([lessonId, order])
  @@map("conversation_dialogues")
}

model DialogueLine {
  id          String               @id @default(uuid())
  dialogueId  String
  dialogue    ConversationDialogue @relation(fields: [dialogueId], references: [id], onDelete: Cascade)
  speaker     String // e.g. "Serveur", "Client"
  frenchText  String
  englishText String
  audioUrl    String? // null until TTS pipeline exists
  order       Int

  @@index([dialogueId, order])
  @@map("dialogue_lines")
}

model ReadingPassage {
  id       String  @id @default(uuid())
  lessonId String
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String
  bodyFr   String
  bodyEn   String? // translation-toggle support, matches the Vocabulary detail dialog pattern
  audioUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
  @@map("reading_passages")
}

model ListeningClip {
  id           String  @id @default(uuid())
  lessonId     String
  lesson       Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  audioUrl     String? // null until TTS/audio pipeline exists
  transcriptFr String
  transcriptEn String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
  @@map("listening_clips")
}

// Serves both in-lesson practice and the lesson-ending quiz (CLAUDE.md
// "Quiz" section) — same shape, no separate Quiz table needed at this
// scale; a lesson's quiz is simply "its exercises, in order."
model Exercise {
  id            String       @id @default(uuid())
  lessonId      String
  lesson        Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type          ExerciseType
  prompt        String
  options       String[] // choices for multiple_choice/match; empty for free-text types
  correctAnswer String // canonical answer; for match/arrange, a serialized reference order
  audioUrl      String?
  imageUrl      String?
  skillKey      SkillKey // which skill this trains — feeds MistakeLog on a wrong attempt
  order         Int
  points        Int      @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts ExerciseAttempt[]

  @@index([lessonId, order])
  @@map("exercises")
}

model ExerciseAttempt {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  submittedAnswer String
  isCorrect       Boolean

  createdAt DateTime @default(now())

  @@index([userId, exerciseId])
  @@index([userId, createdAt])
  @@map("exercise_attempts")
}

// One row per (user, lesson). progress drives continueLesson/todaysLesson
// selection: continueLesson = most recently updated row with 1-99 progress;
// todaysLesson = next recommended lesson (see DashboardService for the
// selection algorithm and its documented adaptive-learning placeholder).
model LessonProgress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress  Int      @default(0) // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId, updatedAt])
  @@map("lesson_progress")
}

// ---------------------------------------------------------------------------
// Skill scores
// ---------------------------------------------------------------------------

// Latest-known score per (user, skill). Written whenever a scoring event
// happens elsewhere (quiz, pronunciation drill, etc. — out of scope today).
// Dashboard reads the single latest snapshot per skill; see open question
// in README about live-compute vs. materialized scoring.
model SkillScoreSnapshot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillKey  SkillKey
  score     Int // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, skillKey])
  @@index([userId])
  @@map("skill_score_snapshots")
}

// ---------------------------------------------------------------------------
// Mistake tracking (drives weakTopics)
// ---------------------------------------------------------------------------

model MistakeLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicTitle String // e.g. "Passé composé vs. imparfait"
  skillKey   SkillKey
  correct    Boolean // false = mistake, true = a correct attempt on that topic (for accuracy denominator)

  createdAt DateTime @default(now())

  @@index([userId, topicTitle])
  @@index([userId, createdAt])
  @@map("mistake_logs")
}

// ---------------------------------------------------------------------------
// Achievements / gamification
// ---------------------------------------------------------------------------

model Achievement {
  id          String          @id @default(uuid())
  code        String          @unique // stable machine key, e.g. "streak_7"
  title       String
  description String
  icon        AchievementIcon

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement  @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  progress      Int          @default(0) // 0-100
  unlockedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ---------------------------------------------------------------------------
// Streaks / study time
// ---------------------------------------------------------------------------

// One row per (user, calendar day, UTC). minutesStudied accumulates from
// completed lesson/practice sessions (out of scope today, so seeded/faked).
// Streak & "this week" aggregates are derived from this table in
// DashboardService — see README for the UTC-day-boundary open question.
model DailyActivity {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date // UTC calendar day, normalized to midnight
  minutesStudied Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_activity")
}

// ---------------------------------------------------------------------------
// XP
// ---------------------------------------------------------------------------

// Append-only ledger. Total XP = sum(amount). Today's earned XP and level
// curve are derived in DashboardService (see leveling formula documented
// there). Using a ledger (not a running counter) keeps this auditable and
// avoids race conditions from concurrent XP awards.
model XpTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String // e.g. "lesson_complete", "quiz_perfect", "streak_bonus"

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

// ---------------------------------------------------------------------------
// Exams — modeled on real TEF Canada structure (see docs/EXAM_STRUCTURE.md):
// 4 sections (reading/writing/listening/speaking comprehension+expression),
// each with real durations and point scales. Reading/listening are
// auto-graded multiple choice; writing/speaking are human-graded (score +
// gradedByUserId set later), matching how TEF Canada itself works.
// ---------------------------------------------------------------------------

model Exam {
  id            String    @id @default(uuid())
  level         CEFRLevel
  title         String
  description   String?
  availableFrom DateTime
  published     Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sections ExamSection[]
  attempts ExamAttempt[]

  @@index([level, availableFrom])
  @@map("exams")
}

model ExamSection {
  id              String          @id @default(uuid())
  examId          String
  exam            Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  type            ExamSectionType
  title           String
  durationMinutes Int
  maxScore        Int
  order           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions ExamQuestion[]
  responses ExamSectionResponse[]

  @@index([examId, order])
  @@map("exam_sections")
}

model ExamQuestion {
  id            String           @id @default(uuid())
  sectionId     String
  section       ExamSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type          ExamQuestionType
  prompt        String
  passageText   String? // reading comprehension source text
  audioUrl      String? // listening comprehension audio
  options       String[] // multiple_choice choices
  correctAnswer String? // null for writing_task/speaking_task — human-graded
  points        Int
  order         Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses ExamSectionResponse[]

  @@index([sectionId, order])
  @@map("exam_questions")
}

model ExamAttempt {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  status      ExamAttemptStatus @default(IN_PROGRESS)
  startedAt   DateTime          @default(now())
  submittedAt DateTime?
  totalScore  Int?
  clbLevel    Int? // Canadian Language Benchmark, 1-12 — set once fully graded

  responses ExamSectionResponse[]

  @@index([userId, examId])
  @@index([userId, status])
  @@map("exam_attempts")
}

// One row per (attempt, question). isCorrect is set immediately for
// auto-graded multiple_choice; score/gradedByUserId/gradedAt are set later
// by an admin for writing_task/speaking_task, mirroring TEF Canada's real
// two-independent-evaluator model for those sections.
model ExamSectionResponse {
  id              String       @id @default(uuid())
  attemptId       String
  attempt         ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sectionId       String
  section         ExamSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questionId      String
  question        ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  submittedAnswer String? // text answer or speech transcript
  audioUrl        String? // speaking_task recording
  isCorrect       Boolean? // auto-graded multiple_choice
  score           Int? // human-graded writing/speaking
  gradedByUserId  String?
  gradedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@map("exam_section_responses")
}

// ---------------------------------------------------------------------------
// Pronunciation / speech recognition (Whisper integration point)
// ---------------------------------------------------------------------------

// Generic pronunciation-attempt record regardless of where it was triggered
// from (a vocabulary word's practice button, a lesson exercise, or an exam
// speaking section). audioUrl points at Supabase Storage; transcript/score/
// feedback are null until the Whisper transcription + scoring pipeline
// processes it (see src/services/speech.service.ts — needs a real
// WHISPER_API_KEY to actually run, currently scaffolded not wired).
model PronunciationAttempt {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            PronunciationSource
  targetText        String // what the user was supposed to say
  audioUrl          String // Supabase Storage URL of their recording
  transcript        String? // Whisper transcription result
  score             Int? // 0-100
  feedback          Json? // structured word-level feedback
  vocabularyWordId  String?
  vocabularyWord    VocabularyWord?     @relation(fields: [vocabularyWordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@map("pronunciation_attempts")
}

// ---------------------------------------------------------------------------
// Vocabulary
// ---------------------------------------------------------------------------

// Shared catalog word (not per-user). `unitTitle` is intentionally a plain
// free-text label, NOT a foreign key to `Unit` — see
// docs/BACKEND_API_CONTRACT_VOCABULARY.md open question #2. Linking
// vocabulary to real curriculum units is a real design decision (does one
// lesson "teach" a fixed set of words? can a word appear in multiple units?)
// that should be made deliberately, not implied by adding a relation here.
//
// Translations (English + any native language) deliberately live in
// `VocabularyTranslation`, not as fixed columns here (no `english`,
// `nepali`, `hindi`, ...) — see `Language`/`VocabularyTranslation` below.
// This lets new languages be added purely as data, with no schema change.
model VocabularyWord {
  id                 String        @id @default(uuid())
  french             String
  gender             WordGender? // null for anything that isn't a noun
  partOfSpeech       PartOfSpeech
  pronunciationIpa   String
  audioUrl           String? // null until a TTS pipeline exists (out of scope)
  exampleFr          String
  exampleEn          String
  imageUrl           String? // null until an image pipeline exists (out of scope)
  synonyms           String[] // display text only, not relations to other words
  commonMistake      String?
  level              CEFRLevel
  unitTitle          String // free-text category label, e.g. "Greetings" — see note above

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userProgress UserVocabularyProgress[]
  lessonLinks  LessonVocabulary[]
  pronunciationAttempts PronunciationAttempt[]
  translations VocabularyTranslation[]

  @@index([level])
  @@index([unitTitle])
  @@map("vocabulary_words")
}

// One supported UI/translation language. `code` is the ISO 639-1 code used
// everywhere else (User.primaryLanguageCode, VocabularyTranslation.languageCode).
// Adding a new language is a pure data operation (admin creates a row here) —
// no schema or code change required, per the scalability requirement this
// was built against.
model Language {
  code         String  @id // e.g. "en", "ne", "hi"
  name         String // e.g. "English"
  flagEmoji    String // e.g. "🇬🇧"
  displayOrder Int     @default(0)
  enabled      Boolean @default(true)
  isDefault    Boolean @default(false) // exactly one row (English) should be true

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations VocabularyTranslation[]
  users        User[]

  @@index([enabled])
  @@map("languages")
}

// (vocabularyWordId, languageCode) -> translated text. English is stored
// here too (languageCode: "en"), not as a special-cased column, so the
// read path never needs to know English is "special".
model VocabularyTranslation {
  id               String         @id @default(uuid())
  vocabularyWordId String
  vocabularyWord   VocabularyWord @relation(fields: [vocabularyWordId], references: [id], onDelete: Cascade)
  languageCode     String
  language         Language       @relation(fields: [languageCode], references: [code])
  translatedText   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vocabularyWordId, languageCode])
  @@index([languageCode])
  @@map("vocabulary_translations")
}

// Per-(user, word) state: favorite flag + simple manual mastery progression.
// Deliberately NOT a real SRS schedule (no interval/due-date fields) — see
// docs/BACKEND_API_CONTRACT_VOCABULARY.md open question #3/#4. A row only
// exists once a user has favorited or reviewed that word at least once
// (created lazily via upsert); a word with no row is implicitly
// { isFavorite: false, masteryStatus: "new", lastReviewedAt: null }.
model UserVocabularyProgress {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wordId         String
  word           VocabularyWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  isFavorite     Boolean        @default(false)
  masteryStatus  MasteryStatus  @default(new)
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, wordId])
  @@index([userId])
  @@index([userId, isFavorite])
  @@index([userId, masteryStatus])
  @@map("user_vocabulary_progress")
}

// ---------------------------------------------------------------------------
// Universal Lesson Engine content (src/lesson-engine/ — the card-based,
// language-agnostic lesson player). This is a SEPARATE content model from
// Lesson/Unit above (which back the existing French-specific /learn player) —
// the two are unrelated by design. `cardsJson` stores the exact `cards` array
// the engine's own Zod schema (src/lesson-engine/services/content/schema.ts)
// validates client-side; the backend only does structural validation (see
// lessonEngine.validators.ts) rather than duplicating the full per-card-type
// union here, so the engine's card schema has exactly one source of truth.
model LessonEngineLesson {
  id          String  @id // admin-chosen slug, e.g. "fr_a1_lesson_002" — matches the engine's own Lesson.id
  language    String // opaque ISO-ish code (e.g. "fr", "es") — never an enum, the engine is language-agnostic
  level       String // opaque level label (e.g. "A1") — never an enum, for the same reason
  title       String
  description String?
  cardsJson   Json // the validated `cards` array, exactly as authored
  cardCount   Int // denormalized from cardsJson.length, for cheap admin list rendering
  published   Boolean @default(false)

  // Content-access gating: null (the default) means fully public, matching
  // this feature's original no-auth design — nothing that was open before
  // this column existed becomes gated by adding it. A non-null value means
  // the requester must be authenticated AND hold at least this role (rank
  // ADMIN > MODERATOR > PREMIUM > USER), enforced server-side in
  // lessonEngine.service.ts, never just hidden client-side.
  requiredRole Role?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sectionLinks LessonEngineSectionLesson[]

  @@index([language, level])
  @@index([published])
  @@map("lesson_engine_lessons")
}

// ---------------------------------------------------------------------------
// Lesson Engine Course/Section hierarchy — the real Course -> Section ->
// Lesson structure ARCHITECTURE.md originally described, filled in now that
// admin authoring exists. A course is purely organizational (groups sections,
// which group ordered lessons); content-access gating lives on the LESSON
// itself (LessonEngineLesson.requiredRole), not here, so a course can mix
// free preview lessons with premium ones.
// ---------------------------------------------------------------------------

model LessonEngineCourse {
  id           String  @id // admin-chosen slug, e.g. "fr_a1"
  language     String
  level        String
  title        String
  description  String?
  published    Boolean @default(false)
  displayOrder Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sections LessonEngineSection[]

  @@index([language, level])
  @@index([published])
  @@map("lesson_engine_courses")
}

model LessonEngineSection {
  id           String @id @default(uuid())
  courseId     String
  course       LessonEngineCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  displayOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessonLinks LessonEngineSectionLesson[]

  @@index([courseId])
  @@map("lesson_engine_sections")
}

// Ordered join between a section and a lesson. A lesson can appear in more
// than one section/course (e.g. reused across levels), hence a join table
// rather than a foreign key directly on LessonEngineLesson.
model LessonEngineSectionLesson {
  id           String @id @default(uuid())
  sectionId    String
  section      LessonEngineSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       LessonEngineLesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  displayOrder Int    @default(0)

  @@unique([sectionId, lessonId])
  @@index([lessonId])
  @@map("lesson_engine_section_lessons")
}

// ---------------------------------------------------------------------------
// Vocabulary category presentation (icon + display order). `VocabularyWord.
// unitTitle` remains the plain-text category name (unchanged) — this table
// only holds ADMIN-CONTROLLED display metadata for a category name, so a
// category's icon/ordering is never hardcoded in frontend source. A category
// name with no row here just falls back to a generic icon + alphabetical
// order (never a broken/missing state). `icon` is a curated string key (see
// server/src/validators/admin.validators.ts and the frontend's matching
// lookup) — never freeform, so it can never reference a nonexistent icon.
model VocabularyCategoryMeta {
  name         String   @id
  icon         String   @default("tag")
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("vocabulary_category_meta")
}
