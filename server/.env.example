# Copy this file to .env and fill in real values.
# Never commit .env — see server/.gitignore.

# --- Runtime ---
NODE_ENV=development
PORT=4000

# --- Database ---
# Local dev (docker-compose.yml default):
DATABASE_URL="postgresql://frenchmaster:frenchmaster@localhost:5432/frenchmaster?schema=public"
# DIRECT_URL is unused locally (DATABASE_URL already points directly at Postgres).
# Required on Supabase — see "Database" section of docs/DEPLOYMENT.md.
DIRECT_URL=

# --- Auth: JWT ---
# Generate strong random secrets, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-random-64-char-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-64-char-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN_DAYS=30

# --- Auth: Google OAuth (NOT configured — route 501s until these are real) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth: Apple Sign In (NOT configured — route 501s until these are real) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Redis / BullMQ (docker-compose.yml default) ---
REDIS_URL="redis://localhost:6379"

# --- CORS / frontend origin ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Storage: Supabase or Cloudflare R2 (NOT used yet — out of scope; pick one) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# --- AI providers (NOT used yet — out of scope beyond plumbing) ---
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Payments (NOT used yet — out of scope) ---
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# --- Email / SMTP (NOT used yet — out of scope beyond plumbing) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
