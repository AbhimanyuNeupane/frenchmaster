          { "id": "w2", "text": "muchas" },
          { "id": "w1", "text": "Hola," },
          { "id": "w3", "text": "gracias" }
        ]
      },
      "validation": { "correctOrder": ["w1", "w2", "w3"] },
      "metadata": { "estimatedSeconds": 30 }
    },
    {
      "id": "c11",
      "type": "SpeakingCard",
      "title": "Your turn to speak",
      "content": {
        "prompt": "Repeat this greeting out loud.",
        "targetText": "¡Hola, muchas gracias!",
