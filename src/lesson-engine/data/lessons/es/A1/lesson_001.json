        "questions": [
          {
            "id": "q1",
            "kind": "mc",
            "prompt": "How do you say \"Goodbye\"?",
            "options": [
              { "id": "a", "text": "Hola" },
              { "id": "b", "text": "Adiós" },
              { "id": "c", "text": "Gracias" }
            ]
          },
          { "id": "q2", "kind": "tf", "prompt": "\"Buenos días\" is a morning greeting." }
        ]
      },
      "validation": { "answers": { "q1": "b", "q2": true } },
      "metadata": { "estimatedSeconds": 40 }
    },
    {
      "id": "c13",
      "type": "SummaryCard",
      "title": "What you learned",
      "content": {
        "heading": "Key takeaways",
        "points": [
          "Hola works as a greeting any time of day",
          "Buenos días / Buenas tardes / Buenas noches by time",
          "Gracias and Por favor for politeness",
          "Adiós to say goodbye"
        ]
      },
      "metadata": { "estimatedSeconds": 20 }
    },
    {
      "id": "c14",
