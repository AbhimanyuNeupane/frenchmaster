      "content": { "front": "Adiós", "back": "Goodbye", "hint": "Tap to reveal" },
      "metadata": { "estimatedSeconds": 15 }
    },
    {
      "id": "c6",
      "type": "MultipleChoiceCard",
      "title": "Choose the word",
      "content": {
        "prompt": "Which word means \"Thank you\"?",
        "options": [
          { "id": "a", "text": "Hola" },
          { "id": "b", "text": "Gracias" },
          { "id": "c", "text": "Adiós" },
          { "id": "d", "text": "Por favor" }
        ]
      },
      "validation": { "correctOptionId": "b" },
      "metadata": { "estimatedSeconds": 20 }
    },
    {
      "id": "c7",
      "type": "TrueFalseCard",
      "title": "True or false?",
      "content": { "statement": "\"Buenas noches\" is used in the morning." },
      "validation": { "answer": false },
      "metadata": { "estimatedSeconds": 15 }
    },
    {
      "id": "c8",
      "type": "FillBlankCard",
      "title": "Complete the phrase",
      "content": { "textWithBlanks": "¡___! ¿Cómo estás?", "hint": "A casual greeting" },
      "validation": { "acceptedAnswers": ["Hola", "hola"] },
      "metadata": { "estimatedSeconds": 25 }
    },
    {
      "id": "c9",
      "type": "MatchingCard",
      "title": "Match the pairs",
      "content": {
