          { "id": "p1", "left": "Hola", "right": "Hello" },
          { "id": "p2", "left": "Gracias", "right": "Thank you" },
          { "id": "p3", "left": "Adiós", "right": "Goodbye" },
          { "id": "p4", "left": "Sí", "right": "Yes" }
        ]
      },
      "metadata": { "estimatedSeconds": 40 }
    },
    {
      "id": "c10",
      "type": "DragOrderCard",
