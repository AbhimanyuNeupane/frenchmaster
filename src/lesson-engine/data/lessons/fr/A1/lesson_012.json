    },
    {
      "id": "c14",
      "type": "MultipleSelectCard",
      "title": "Quelles expressions sont polies au restaurant ?",
      "content": {
        "prompt": "Select every polite restaurant expression.",
        "options": [
          { "id": "a", "text": "Je voudrais..." },
          { "id": "b", "text": "Donne-moi ça !" },
          { "id": "c", "text": "Pourriez-vous..." },
          { "id": "d", "text": "L'addition, s'il vous plaît." }
        ]
      },
      "validation": { "correctOptionIds": ["a", "c", "d"] },
      "metadata": { "estimatedSeconds": 30 }
    },
    {
      "id": "c15",
      "type": "ConversationCard",
      "title": "Commander un repas",
      "content": {
        "scenario": "Restaurant",
        "lines": [
          { "speaker": "Serveur", "text": "Bonsoir, vous avez choisi ?", "translation": "Good evening, have you decided?" },
          { "speaker": "Client", "text": "Oui, je voudrais cette entrée et le plat du jour.", "translation": "Yes, I'd like this starter and the dish of the day." },
          { "speaker": "Serveur", "text": "Très bien. Et comme boisson ?", "translation": "Very good. And to drink?" },
          { "speaker": "Client", "text": "De l'eau, s'il vous plaît. Et l'addition à la fin.", "translation": "Water, please. And the bill at the end." }
        ]
      },
      "metadata": { "estimatedSeconds": 45 }
    },
    {
      "id": "c16",
      "type": "SpeakingCard",
      "title": "À vous de parler",
