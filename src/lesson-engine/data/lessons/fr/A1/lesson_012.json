          { "id": "b", "text": "le poulet" },
          { "id": "c", "text": "la salade" }
        ]
      },
      "validation": { "correctOptionId": "b" },
      "metadata": { "estimatedSeconds": 25 }
    },
    {
      "id": "c11",
      "type": "MatchingCard",
      "title": "Associez le mot à sa traduction",
      "content": {
        "prompt": "Match each restaurant word to its English meaning.",
        "pairs": [
          { "id": "p1", "left": "l'entrée", "right": "the starter" },
          { "id": "p2", "left": "l'addition", "right": "the bill" },
          { "id": "p3", "left": "la carte", "right": "the menu" },
          { "id": "p4", "left": "réserver", "right": "to book/reserve" }
        ]
      },
      "metadata": { "estimatedSeconds": 40 }
    },
    {
      "id": "c12",
      "type": "TrueFalseCard",
      "title": "Vrai ou faux ?",
      "content": {
        "statement": "\"Je veux\" est plus poli que \"je voudrais\"."
      },
      "validation": { "answer": false },
      "metadata": { "estimatedSeconds": 15 }
    },
    {
      "id": "c13",
