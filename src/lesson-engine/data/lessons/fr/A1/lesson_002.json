      "content": {
        "prompt": "Match each question to its natural answer.",
        "pairs": [
          { "id": "p1", "left": "Comment vous appelez-vous ?", "right": "Je m'appelle Marc." },
          { "id": "p2", "left": "Quel âge avez-vous ?", "right": "J'ai vingt-cinq ans." },
          { "id": "p3", "left": "D'où venez-vous ?", "right": "Je viens du Canada." },
          { "id": "p4", "left": "Vous êtes français ?", "right": "Non, je suis belge." }
        ]
      },
      "metadata": { "estimatedSeconds": 40 }
    },
    {
      "id": "c14",
      "type": "DragOrderCard",
      "title": "Construisez la phrase",
      "content": {
        "prompt": "Arrange the words to say \"My name is Claire and I am twenty years old.\"",
        "items": [
          { "id": "w4", "text": "vingt ans." },
          { "id": "w1", "text": "Je m'appelle" },
          { "id": "w3", "text": "j'ai" },
          { "id": "w2", "text": "Claire et" }
        ]
      },
      "validation": { "correctOrder": ["w1", "w2", "w3", "w4"] },
      "metadata": { "estimatedSeconds": 30 }
    },
    {
      "id": "c15",
      "type": "TrueFalseCard",
      "title": "Vrai ou faux ?",
      "content": {
        "statement": "Pendant un entretien TEF/TCF, il est recommandé d'utiliser \"tu\" avec l'examinateur."
      },
