          { "speaker": "Examinateur", "text": "Quel âge avez-vous, Karim ?", "translation": "How old are you, Karim?" },
          { "speaker": "Candidat", "text": "J'ai vingt-huit ans.", "translation": "I am twenty-eight years old." },
          { "speaker": "Examinateur", "text": "Et d'où venez-vous ?", "translation": "And where are you from?" },
          { "speaker": "Candidat", "text": "Je viens du Maroc.", "translation": "I come from Morocco." }
