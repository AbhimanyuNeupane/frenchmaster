    },
    {
      "id": "c12",
      "type": "FillBlankCard",
      "title": "Complétez la phrase",
      "content": {
        "textWithBlanks": "J'___ vingt ans.",
        "hint": "The verb \"avoir\" (to have), 1st person singular"
      },
      "validation": { "acceptedAnswers": ["ai"] },
      "metadata": { "estimatedSeconds": 20 }
    },
    {
      "id": "c13",
      "type": "MatchingCard",
