      "content": {
        "scenario": "At a bakery",
        "lines": [
          { "speaker": "Vous", "text": "Bonjour !", "translation": "Hello!" },
          { "speaker": "Boulanger", "text": "Bonjour ! Vous désirez ?", "translation": "Hello! What would you like?" },
          { "speaker": "Vous", "text": "Une baguette, s'il vous plaît.", "translation": "A baguette, please." },
          { "speaker": "Boulanger", "text": "Voilà. Merci, au revoir !", "translation": "Here you go. Thank you, goodbye!" }
        ]
      },
